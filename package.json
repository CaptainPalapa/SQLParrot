{
  "name": "sql-parrot",
  "version": "1.9.0",
  "description": "Database Server Snapshot Management Tool",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "start:docker": "cd backend && npm start",
    "tauri": "npx tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build && node src-tauri/scripts/patch-nsis-installer.js",
    "test": "jest",
    "test:api": "jest tests/snapshot-rollback-api.spec.js",
    "test:profiles": "jest tests/profile-management-api.spec.js",
    "test:history": "jest tests/history-api.spec.js",
    "test:storage": "jest backend/utils/__tests__/metadataStorageSqlite.test.js",
    "test:all": "jest tests/ backend/utils/__tests__/",
    "test:watch": "jest --watch",
    "bump": "node scripts/bump-version.js",
    "screenshots": "node scripts/capture-screenshots.js",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{js,jsx}": "eslint --config frontend/eslint.config.js --report-unused-disable-directives --max-warnings 0",
    "backend/**/*.js": "eslint --config backend/eslint.config.js --report-unused-disable-directives --max-warnings 0",
    "{tests,scripts}/**/*.js": "eslint --config eslint.config.js --report-unused-disable-directives --max-warnings 0",
    "*.js": "eslint --config eslint.config.js --report-unused-disable-directives --max-warnings 0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tauri-apps/cli": "^2.10.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.1.0",
    "mssql": "^12.7.0",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2"
  }
}
